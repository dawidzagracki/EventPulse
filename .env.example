# ===========================================================================
# EventPulse — environment template. Copy to .env for local dev (.env is gitignored).
# Local defaults below target the docker-compose stack (full parity with OVH prod).
# ===========================================================================

# ---- Runtime ----
ASPNETCORE_ENVIRONMENT=Development

# ---- PostgreSQL (local: docker compose 'postgres') ----
POSTGRES_USER=eventpulse
POSTGRES_PASSWORD=eventpulse_dev
POSTGRES_DB=eventpulse
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=eventpulse;Username=eventpulse;Password=eventpulse_dev

# ---- Redis (SignalR backplane + cache + Hangfire) ----
ConnectionStrings__Redis=redis:6379

# ---- Object storage (local: MinIO; prod: OVH Object Storage S3-compatible) ----
Storage__Endpoint=http://minio:9000
Storage__AccessKey=minioadmin
Storage__SecretKey=minioadmin
Storage__Bucket=eventpulse
Storage__ForcePathStyle=true
Storage__Region=us-east-1

# ---- Email (local: Mailhog SMTP; prod: Mailgun API) ----
Email__Provider=Smtp            # Smtp (local/Mailhog) | Mailgun (staging/prod)
Email__From=events@eventpulse.local
Email__Smtp__Host=mailhog
Email__Smtp__Port=1025
Email__Mailgun__ApiKey=
Email__Mailgun__Domain=

# ---- JWT ----
Jwt__Issuer=eventpulse
Jwt__Audience=eventpulse
Jwt__SigningKey=dev-only-signing-key-change-me-min-32-chars-long
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=14

# ---- Web push (VAPID) ----
Push__VapidPublicKey=
Push__VapidPrivateKey=
Push__Subject=mailto:events@eventpulse.local

# ---- AI assistant (Claude API; empty = stub implementation locally) ----
Ai__Provider=Stub               # Stub | Anthropic
Ai__Anthropic__ApiKey=
Ai__Anthropic__Model=claude-opus-4-7

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8080
