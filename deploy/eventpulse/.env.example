# EventPulse — produkcja. Skopiuj do .env i uzupełnij. NIE commituj .env.
# Sekrety wygeneruj na serwerze, np.:  openssl rand -base64 48

# ── Baza danych (wewnętrzna) ──
POSTGRES_USER=eventpulse
POSTGRES_PASSWORD=ZMIEN_mocne_haslo
POSTGRES_DB=eventpulse
ConnectionStrings__Postgres=Host=ep-postgres;Port=5432;Database=eventpulse;Username=eventpulse;Password=ZMIEN_mocne_haslo

# ── Redis (włącza backplane SignalR dla 3 replik — WYMAGANE przy >1 instancji) ──
ConnectionStrings__Redis=ep-redis:6379

# ── Obiektowe (zdjęcia). Self-hosted MinIO; można podmienić na zewnętrzne S3/OVH. ──
Storage__Provider=S3
Storage__Endpoint=http://ep-minio:9000
Storage__AccessKey=ZMIEN_minio_user
Storage__SecretKey=ZMIEN_minio_haslo
Storage__Bucket=eventpulse
Storage__ForcePathStyle=true

# ── JWT (PODPIS tokenów — silny sekret, min. 32 znaki) ──
Jwt__SigningKey=ZMIEN_dlugi_losowy_sekret_min_32_znaki
Jwt__Issuer=eventpulse
Jwt__Audience=eventpulse

# ── CORS + adresy publiczne (MUSZĄ zgadzać się z domeną) ──
Cors__Origins__0=https://eventpulse.pl
Cors__Origins__1=https://www.eventpulse.pl
App__ParticipantLinkBaseUrl=https://eventpulse.pl/p

# ── Pierwszy super-admin (bootstrap przy pustej bazie; potem ignorowane) ──
Bootstrap__AdminEmail=admin@eventpulse.pl
Bootstrap__AdminPassword=ZMIEN_haslo_pierwszego_admina
Bootstrap__AdminName=Administrator
Bootstrap__TenantName=EventPulse

# ── E-mail (do zaproszeń). OPCJONALNE — można wdrożyć bez i dodać później. ──
Email__Provider=Mailgun
Email__From=no-reply@eventpulse.pl
Email__FromName=EventPulse
Email__Mailgun__ApiKey=ZMIEN
Email__Mailgun__Domain=mg.eventpulse.pl
# Region EU? Odkomentuj (domyślnie US = https://api.mailgun.net):
# Email__Mailgun__BaseUrl=https://api.eu.mailgun.net
#
# Alternatywnie zwykłe SMTP:
# Email__Provider=Smtp
# Email__Smtp__Host=...
# Email__Smtp__Port=587
# Email__Smtp__UseSsl=true
# Email__Smtp__User=...
# Email__Smtp__Password=...

# ── AI asystent (opcjonalnie) ──
# Ai__Provider=Anthropic
# Ai__Anthropic__ApiKey=ZMIEN
