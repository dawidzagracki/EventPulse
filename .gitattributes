# Normalize line endings to LF in the repo; checkout native on Windows.
* text=auto eol=lf

*.cs        text eol=lf
*.csproj    text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf

# Windows-specific scripts keep CRLF
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Binaries
*.png       binary
*.jpg       binary
*.ico       binary
*.pdf       binary
*.xlsx      binary
